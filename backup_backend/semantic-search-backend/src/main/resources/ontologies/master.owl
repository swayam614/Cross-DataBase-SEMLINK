<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticsearch.com/master#"
     xml:base="http://www.semanticsearch.com/master"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">

<owl:Ontology rdf:about="http://www.semanticsearch.com/master">

    <!-- FIXED: Use classpath instead of HTTP IRIs -->
    <owl:imports rdf:resource="classpath:/owl/schema.owl"/>
    <owl:imports rdf:resource="classpath:/owl/link.owl"/>

</owl:Ontology>

</rdf:RDF>