<rdf:RDF
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:apple="http://www.semanticsearch.com/apple#"
    xmlns:schema="http://www.semanticsearch.com/schema#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#">
  <owl:Ontology rdf:about="http://www.semanticsearch.com/master">
    <owl:imports rdf:resource="http://www.semanticsearch.com/schema"/>
    <owl:imports rdf:resource="http://www.semanticsearch.com/link"/>
  </owl:Ontology>
  <owl:Ontology rdf:about="http://www.semanticsearch.com/apple">
    <owl:imports rdf:resource="http://www.semanticsearch.com/schema"/>
  </owl:Ontology>
  <schema:Product rdf:about="http://www.semanticsearch.com/apple#iPhone15_AppleStore">
    <schema:rating rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal"
    >4.7</schema:rating>
    <schema:productName>Apple iPhone 15</schema:productName>
    <schema:productLink>https://apple.com/iphone15</schema:productLink>
    <schema:price rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal"
    >80999</schema:price>
    <schema:hasSource>
      <schema:Source rdf:about="http://www.semanticsearch.com/apple#AppleStore">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
      </schema:Source>
    </schema:hasSource>
    <schema:hasCategory>
      <schema:Category rdf:about="http://www.semanticsearch.com/apple#Smartphone">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
      </schema:Category>
    </schema:hasCategory>
    <schema:hasBrand>
      <schema:Brand rdf:about="http://www.semanticsearch.com/apple#Apple">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
      </schema:Brand>
    </schema:hasBrand>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
  </schema:Product>
</rdf:RDF>
