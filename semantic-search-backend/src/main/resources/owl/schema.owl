<?xml version="1.0"?>
<rdf:RDF
    xml:base="http://www.semanticsearch.com/schema"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:schema="http://www.semanticsearch.com/schema#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#">

  <!-- Ontology -->
  <owl:Ontology rdf:about="http://www.semanticsearch.com/schema"/>

  <!-- Classes -->
  <owl:Class rdf:about="http://www.semanticsearch.com/schema#Category"/>
  <owl:Class rdf:about="http://www.semanticsearch.com/schema#Brand"/>
  <owl:Class rdf:about="http://www.semanticsearch.com/schema#Product"/>
  <owl:Class rdf:about="http://www.semanticsearch.com/schema#Source"/>

  <!-- Temporal Classes -->
  <owl:Class rdf:about="http://www.semanticsearch.com/schema#Price"/>
  <owl:Class rdf:about="http://www.semanticsearch.com/schema#Rating"/>

  <!-- Relationships -->
  <owl:ObjectProperty rdf:about="http://www.semanticsearch.com/schema#hasCategory">
    <rdfs:domain rdf:resource="http://www.semanticsearch.com/schema#Product"/>
    <rdfs:range rdf:resource="http://www.semanticsearch.com/schema#Category"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://www.semanticsearch.com/schema#hasSource">
    <rdfs:domain rdf:resource="http://www.semanticsearch.com/schema#Product"/>
    <rdfs:range rdf:resource="http://www.semanticsearch.com/schema#Source"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://www.semanticsearch.com/schema#hasBrand">
    <rdfs:domain rdf:resource="http://www.semanticsearch.com/schema#Product"/>
    <rdfs:range rdf:resource="http://www.semanticsearch.com/schema#Brand"/>
  </owl:ObjectProperty>

  <!-- Temporal Relations -->
  <owl:ObjectProperty rdf:about="http://www.semanticsearch.com/schema#hasPrice">
    <rdfs:domain rdf:resource="http://www.semanticsearch.com/schema#Product"/>
    <rdfs:range rdf:resource="http://www.semanticsearch.com/schema#Price"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://www.semanticsearch.com/schema#hasRating">
    <rdfs:domain rdf:resource="http://www.semanticsearch.com/schema#Product"/>
    <rdfs:range rdf:resource="http://www.semanticsearch.com/schema#Rating"/>
  </owl:ObjectProperty>

  <!-- Product Info -->
  <owl:DatatypeProperty rdf:about="http://www.semanticsearch.com/schema#productName">
    <rdfs:domain rdf:resource="http://www.semanticsearch.com/schema#Product"/>
    <rdfs:range rdf:resource="xsd:string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://www.semanticsearch.com/schema#productLink">
    <rdfs:domain rdf:resource="http://www.semanticsearch.com/schema#Product"/>
    <rdfs:range rdf:resource="xsd:string"/>
  </owl:DatatypeProperty>

  <!-- Price Properties -->
  <owl:DatatypeProperty rdf:about="http://www.semanticsearch.com/schema#priceValue">
    <rdfs:domain rdf:resource="http://www.semanticsearch.com/schema#Price"/>
    <rdfs:range rdf:resource="xsd:decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://www.semanticsearch.com/schema#priceTimestamp">
    <rdfs:domain rdf:resource="http://www.semanticsearch.com/schema#Price"/>
    <rdfs:range rdf:resource="xsd:dateTime"/>
  </owl:DatatypeProperty>

  <!-- Rating Properties -->
  <owl:DatatypeProperty rdf:about="http://www.semanticsearch.com/schema#ratingValue">
    <rdfs:domain rdf:resource="http://www.semanticsearch.com/schema#Rating"/>
    <rdfs:range rdf:resource="xsd:decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://www.semanticsearch.com/schema#ratingTimestamp">
    <rdfs:domain rdf:resource="http://www.semanticsearch.com/schema#Rating"/>
    <rdfs:range rdf:resource="xsd:dateTime"/>
  </owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticsearch.com/schema#createdAt">
    <rdfs:domain rdf:resource="http://www.semanticsearch.com/schema#Product"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
</owl:DatatypeProperty>

</rdf:RDF>