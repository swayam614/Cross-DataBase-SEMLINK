<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticsearch.com/flipkart#"
     xml:base="http://www.semanticsearch.com/flipkart"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:schema="http://www.semanticsearch.com/schema#"
     xmlns:flipkart="http://www.semanticsearch.com/flipkart#">

<owl:Ontology rdf:about="http://www.semanticsearch.com/flipkart">
    <owl:imports rdf:resource="http://www.semanticsearch.com/schema"/>
</owl:Ontology>

<!-- Source -->
<owl:NamedIndividual rdf:about="#Flipkart">
    <rdf:type rdf:resource="schema:Source"/>
</owl:NamedIndividual>

<!-- Brands -->
<owl:NamedIndividual rdf:about="#Apple">
    <rdf:type rdf:resource="schema:Brand"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Samsung">
    <rdf:type rdf:resource="schema:Brand"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#OnePlus">
    <rdf:type rdf:resource="schema:Brand"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Dell">
    <rdf:type rdf:resource="schema:Brand"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#HP">
    <rdf:type rdf:resource="schema:Brand"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Sony">
    <rdf:type rdf:resource="schema:Brand"/>
</owl:NamedIndividual>

<!-- Categories -->
<owl:NamedIndividual rdf:about="#Smartphone">
    <rdf:type rdf:resource="schema:Category"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Laptop">
    <rdf:type rdf:resource="schema:Category"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Headphones">
    <rdf:type rdf:resource="schema:Category"/>
</owl:NamedIndividual>

<!-- PRODUCTS -->

<!-- 1 -->
<owl:NamedIndividual rdf:about="#iPhone15_Flipkart">
    <rdf:type rdf:resource="http://www.semanticsearch.com/schema#Product"/>
    <schema:hasBrand rdf:resource="#Apple"/>
    <schema:hasCategory rdf:resource="#Smartphone"/>
    <schema:hasSource rdf:resource="#Flipkart"/>
    <schema:price rdf:datatype="xsd:decimal">78999</schema:price>
    <schema:productLink>https://flipkart.com/iphone15</schema:productLink>
    <schema:productName>Apple iPhone 15</schema:productName>
    <schema:rating rdf:datatype="xsd:decimal">4.5</schema:rating>
</owl:NamedIndividual>

