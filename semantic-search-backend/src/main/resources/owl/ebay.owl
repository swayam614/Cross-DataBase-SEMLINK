<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticsearch.com/ebay#"
     xml:base="http://www.semanticsearch.com/ebay"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:schema="http://www.semanticsearch.com/schema#"
     xmlns:ebay="http://www.semanticsearch.com/ebay#">

<owl:Ontology rdf:about="http://www.semanticsearch.com/ebay">
    <owl:imports rdf:resource="http://www.semanticsearch.com/schema"/>
</owl:Ontology>

<!-- Source -->
<owl:NamedIndividual rdf:about="#eBay">
    <rdf:type rdf:resource="schema:Source"/>
</owl:NamedIndividual>

<!-- Brands -->
<owl:NamedIndividual rdf:about="#Apple"><rdf:type rdf:resource="schema:Brand"/></owl:NamedIndividual>
<owl:NamedIndividual rdf:about="#Samsung"><rdf:type rdf:resource="schema:Brand"/></owl:NamedIndividual>
<owl:NamedIndividual rdf:about="#OnePlus"><rdf:type rdf:resource="schema:Brand"/></owl:NamedIndividual>
<owl:NamedIndividual rdf:about="#Dell"><rdf:type rdf:resource="schema:Brand"/></owl:NamedIndividual>
<owl:NamedIndividual rdf:about="#HP"><rdf:type rdf:resource="schema:Brand"/></owl:NamedIndividual>
<owl:NamedIndividual rdf:about="#Sony"><rdf:type rdf:resource="schema:Brand"/></owl:NamedIndividual>

<!-- Categories -->
<owl:NamedIndividual rdf:about="#Smartphone"><rdf:type rdf:resource="schema:Category"/></owl:NamedIndividual>
<owl:NamedIndividual rdf:about="#Laptop"><rdf:type rdf:resource="schema:Category"/></owl:NamedIndividual>
<owl:NamedIndividual rdf:about="#Headphones"><rdf:type rdf:resource="schema:Category"/></owl:NamedIndividual>

<!-- PRODUCTS -->

<!-- Same products, different prices -->

<owl:NamedIndividual rdf:about="#iPhone15_eBay">
    <rdf:type rdf:resource="http://www.semanticsearch.com/schema#Product"/>
    <schema:hasBrand rdf:resource="#Apple"/>
    <schema:hasCategory rdf:resource="#Smartphone"/>
    <schema:hasSource rdf:resource="#eBay"/>
    <schema:price rdf:datatype="xsd:decimal">78500</schema:price>
    <schema:productLink>https://ebay.com/iphone15</schema:productLink>
    <schema:productName>Apple iPhone 15</schema:productName>
    <schema:rating rdf:datatype="xsd:decimal">4.5</schema:rating>
</owl:NamedIndividual>

