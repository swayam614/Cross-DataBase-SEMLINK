<?xml version="1.0"?>
<rdf:RDF
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:apple="http://www.semanticsearch.com/apple#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#">

  <!-- Ontology -->
  <owl:Ontology rdf:about="http://www.semanticsearch.com/apple"/>

  <!-- Classes -->
  <owl:Class rdf:about="http://www.semanticsearch.com/apple#Product"/>
  <owl:Class rdf:about="http://www.semanticsearch.com/apple#Price"/>
  <owl:Class rdf:about="http://www.semanticsearch.com/apple#Rating"/>
  <owl:Class rdf:about="http://www.semanticsearch.com/apple#Brand"/>
  <owl:Class rdf:about="http://www.semanticsearch.com/apple#Source"/>
  <owl:Class rdf:about="http://www.semanticsearch.com/apple#Category"/>

  <!-- Properties -->
  <owl:DatatypeProperty rdf:about="http://www.semanticsearch.com/apple#name"/>
  <owl:DatatypeProperty rdf:about="http://www.semanticsearch.com/apple#link"/>
  <owl:DatatypeProperty rdf:about="http://www.semanticsearch.com/apple#priceValue"/>
  <owl:DatatypeProperty rdf:about="http://www.semanticsearch.com/apple#ratingValue"/>

  <owl:ObjectProperty rdf:about="http://www.semanticsearch.com/apple#hasPrice"/>
  <owl:ObjectProperty rdf:about="http://www.semanticsearch.com/apple#hasRating"/>
  <owl:ObjectProperty rdf:about="http://www.semanticsearch.com/apple#hasBrand"/>
  <owl:ObjectProperty rdf:about="http://www.semanticsearch.com/apple#hasSource"/>
  <owl:ObjectProperty rdf:about="http://www.semanticsearch.com/apple#hasCategory"/>

  <!-- Product -->
  <apple:Product rdf:about="http://www.semanticsearch.com/apple#iPhone15_AppleStore">

    <apple:name>Apple iPhone 15</apple:name>
    <apple:link>https://apple.com/iphone15</apple:link>

    <apple:hasBrand rdf:resource="http://www.semanticsearch.com/apple#Apple"/>
    <apple:hasSource rdf:resource="http://www.semanticsearch.com/apple#AppleStore"/>
    <apple:hasCategory rdf:resource="http://www.semanticsearch.com/apple#Smartphone"/>

    <apple:hasPrice rdf:resource="http://www.semanticsearch.com/apple#iPhone15_price"/>
    <apple:hasRating rdf:resource="http://www.semanticsearch.com/apple#iPhone15_rating"/>

  </apple:Product>

  <!-- Price -->
  <apple:Price rdf:about="http://www.semanticsearch.com/apple#iPhone15_price">
    <apple:priceValue rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">70999</apple:priceValue>
  </apple:Price>

  <!-- Rating -->
  <apple:Rating rdf:about="http://www.semanticsearch.com/apple#iPhone15_rating">
    <apple:ratingValue rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">3.7</apple:ratingValue>
  </apple:Rating>

  <!-- Entities -->
  <apple:Brand rdf:about="http://www.semanticsearch.com/apple#Apple"/>
  <apple:Source rdf:about="http://www.semanticsearch.com/apple#AppleStore"/>
  <apple:Category rdf:about="http://www.semanticsearch.com/apple#Smartphone"/>

</rdf:RDF>