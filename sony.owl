<?xml version="1.0"?>
<rdf:RDF
    xmlns="http://www.semanticsearch.com/sony#"
    xml:base="http://www.semanticsearch.com/sony"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#">

    <!-- Ontology -->
    <owl:Ontology rdf:about="http://www.semanticsearch.com/sony"/>

    <!-- ========================= -->
    <!-- CLASSES -->
    <!-- ========================= -->

    <owl:Class rdf:about="#Product"/>
    <owl:Class rdf:about="#Category"/>
    <owl:Class rdf:about="#Brand"/>
    <owl:Class rdf:about="#Source"/>

    <!-- ========================= -->
    <!-- PROPERTIES -->
    <!-- ========================= -->

    <!-- Datatype -->
    <owl:DatatypeProperty rdf:about="#productName"/>
    <owl:DatatypeProperty rdf:about="#price"/>
    <owl:DatatypeProperty rdf:about="#rating"/>
    <owl:DatatypeProperty rdf:about="#productLink"/>

    <!-- Object -->
    <owl:ObjectProperty rdf:about="#hasCategory"/>
    <owl:ObjectProperty rdf:about="#hasSource"/>
    <owl:ObjectProperty rdf:about="#hasBrand"/>

    <!-- ========================= -->
    <!-- INDIVIDUALS -->
    <!-- ========================= -->

    <!-- Brand -->
    <owl:NamedIndividual rdf:about="#Sony">
        <rdf:type rdf:resource="#Brand"/>
    </owl:NamedIndividual>

    <!-- Source -->
    <owl:NamedIndividual rdf:about="#Sony">
        <rdf:type rdf:resource="#Source"/>
    </owl:NamedIndividual>

    <!-- Categories -->
    <owl:NamedIndividual rdf:about="#Headphones">
        <rdf:type rdf:resource="#Category"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#Television">
        <rdf:type rdf:resource="#Category"/>
    </owl:NamedIndividual>

    <!-- ========================= -->
    <!-- PRODUCTS -->
    <!-- ========================= -->

    <owl:NamedIndividual rdf:about="#Sony_WH1000XM5">
        <rdf:type rdf:resource="#Product"/>

        <hasCategory rdf:resource="#Headphones"/>
        <hasSource rdf:resource="#Sony"/>
        <hasBrand rdf:resource="#Sony"/>

        <productName rdf:datatype="xsd:string">Sony WH-1000XM5</productName>
        <price rdf:datatype="xsd:float">29999</price>
        <rating rdf:datatype="xsd:float">4.8</rating>
        <productLink rdf:datatype="xsd:string">https://sony.com/wh1000xm5</productLink>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#Sony_Bravia_55">
        <rdf:type rdf:resource="#Product"/>

        <hasCategory rdf:resource="#Television"/>
        <hasSource rdf:resource="#Sony"/>
        <hasBrand rdf:resource="#Sony"/>

        <productName rdf:datatype="xsd:string">Sony Bravia 55 Inch</productName>
        <price rdf:datatype="xsd:float">79999</price>
        <rating rdf:datatype="xsd:float">4.3</rating>
        <productLink rdf:datatype="xsd:string">https://sony.com/bravia55</productLink>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#Sony_WF1000XM5">
        <rdf:type rdf:resource="#Product"/>

        <hasCategory rdf:resource="#Headphones"/>
        <hasSource rdf:resource="#Sony"/>
        <hasBrand rdf:resource="#Sony"/>

        <productName rdf:datatype="xsd:string">Sony WF-1000XM5</productName>
        <price rdf:datatype="xsd:float">24999</price>
        <rating rdf:datatype="xsd:float">4.7</rating>
        <productLink rdf:datatype="xsd:string">https://sony.com/wf1000xm5</productLink>
    </owl:NamedIndividual>

</rdf:RDF>