<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticsearch.com/samsung#"
     xml:base="http://www.semanticsearch.com/samsung"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:schema="http://www.semanticsearch.com/schema#"
     xmlns:samsung="http://www.semanticsearch.com/samsung#">

<owl:Ontology rdf:about="http://www.semanticsearch.com/samsung">
    <owl:imports rdf:resource="http://www.semanticsearch.com/schema"/>
</owl:Ontology>

<!-- Source -->
<owl:NamedIndividual rdf:about="#SamsungStore">
    <rdf:type rdf:resource="schema:Source"/>
</owl:NamedIndividual>

<!-- Brand -->
<owl:NamedIndividual rdf:about="#Samsung">
    <rdf:type rdf:resource="schema:Brand"/>
</owl:NamedIndividual>

<!-- Categories -->
<owl:NamedIndividual rdf:about="#Smartphone">
    <rdf:type rdf:resource="schema:Category"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Laptop">
    <rdf:type rdf:resource="schema:Category"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Headphones">
    <rdf:type rdf:resource="schema:Category"/>
</owl:NamedIndividual>

<!-- PRODUCTS -->

<!-- 1 -->
<owl:NamedIndividual rdf:about="#GalaxyS23_Samsung">
    <rdf:type rdf:resource="http://www.semanticsearch.com/schema#Product"/>
    <schema:hasBrand rdf:resource="#Samsung"/>
    <schema:hasCategory rdf:resource="#Smartphone"/>
    <schema:hasSource rdf:resource="#SamsungStore"/>
    <schema:price rdf:datatype="xsd:decimal">67999</schema:price>
    <schema:productLink>https://samsung.com/galaxys23</schema:productLink>
    <schema:productName>Samsung Galaxy S23</schema:productName>
    <schema:rating rdf:datatype="xsd:decimal">4.5</schema:rating>
</owl:NamedIndividual>

